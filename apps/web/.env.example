# Supabase（apps/web）
# クラウドdevプロジェクト直結の場合（推奨。docs/05-cloud-dev-setup.md 参照）:
#   Settings → API の Project URL / anon public key を貼る
VITE_SUPABASE_URL=https://<your-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>
VITE_FUNCTIONS_URL=https://<your-ref>.supabase.co/functions/v1

# （参考）ローカルDockerを使う場合は `supabase start` の出力で:
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
